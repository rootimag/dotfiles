#!/usr/bin/env bash

# 笔记存储路径
MEMO_DIR="$HOME/.cache/meno"
mkdir -p "$MEMO_DIR"

# 帮助信息函数
show_help() {
    cat << EOF
用法: $(basename "$0") [内容 | 选项]

选项:
  -h, --help      显示此帮助信息
  [无参数]        进入交互模式 (fzf)
  [文字内容]      快速创建一个新笔记

交互模式快捷键:
  Enter           编辑选中的笔记
  Ctrl-Y          复制笔记内容到剪贴板
  Ctrl-D          删除选中的笔记
  Esc             直接退出
EOF
}

# 参数判断：处理帮助信息
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    show_help
    exit 0
fi

# 自动检测剪贴板工具
if command -v wl-copy &> /dev/null; then
    CLIP_CMD="wl-copy <"
elif command -v xclip &> /dev/null; then
    CLIP_CMD="xclip -selection clipboard <"
else
    CLIP_CMD="echo '错误: 未找到剪贴板工具' >&2"
fi

TIMESTAMP=$(date +%Y-%m-%d_%H-%M-%S)

# 模式切换
if [ $# -gt 0 ]; then
    echo "$*" > "$MEMO_DIR/$TIMESTAMP.txt"
    echo -e "\033[32m[已保存]\033[0m $*"
else
    selected=$(ls -t "$MEMO_DIR" | fzf \
        --height 60% \
        --layout=reverse \
        --border=rounded \
        --preview "cat $MEMO_DIR/{}" \
        --header "目录" \
        --bind "ctrl-d:execute(rm $MEMO_DIR/{})+reload(ls -t $MEMO_DIR)" \
        --bind "ctrl-y:execute-silent($CLIP_CMD $MEMO_DIR/{})+become(echo -e '\033[34m󰅍 已成功复制内容\033[0m')" \
        --prompt "⚡ Memo > ")

    if [ -n "$selected" ] && [ -f "$MEMO_DIR/$selected" ]; then
        ${EDITOR:-nano} "$MEMO_DIR/$selected"
    fi
fi
