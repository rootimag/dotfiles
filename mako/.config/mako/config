# matugen 配色文件

max-history=100
sort=-time

layer=top
anchor=top-right
font=JetBrainsMono Nerd Font 12
width=350
height=150
margin=15
padding=15
border-size=2
border-radius=10
icons=1
max-icon-size=48
markup=1
actions=1
default-timeout=5000
ignore-timeout=0

background-color=#16130bdd
text-color=#e9e2d4
border-color=#dcc66e
progress-color=over #544600

[urgency=low]
border-color=#969080
default-timeout=2000

[urgency=high]
border-color=#ffb4ab
text-color=#ffb4ab
default-timeout=0

[app-name=Spotify]
group-by=app-name
border-color=#aad0b2

[app-name=backlight]
group-by=app-name
history=0
