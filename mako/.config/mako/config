# matugen 配色文件

max-history=100
sort=-time

layer=top
anchor=top-right
font=JetBrainsMono Nerd Font 12
width=350
height=150
margin=15
padding=15
border-size=2
border-radius=10
icons=1
max-icon-size=48
markup=1
actions=1
default-timeout=5000
ignore-timeout=0

background-color=#131318dd
text-color=#e4e1e9
border-color=#bdc2ff
progress-color=over #3c4279

[urgency=low]
border-color=#91909a
default-timeout=2000

[urgency=high]
border-color=#ffb4ab
text-color=#ffb4ab
default-timeout=0

[app-name=Spotify]
group-by=app-name
border-color=#e7b9d6

[app-name=backlight]
group-by=app-name
history=0
